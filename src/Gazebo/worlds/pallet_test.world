<?xml version="1.0"?>
<sdf version="1.6">
  <world name="pallet_test_world">
    <!-- Lighting -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Ground plane -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Pallet at origin, front face (1200mm width) facing camera (-X direction) -->
    <!-- Pallet pose: x, y, z, roll, pitch, yaw -->
    <!-- yaw=1.5708 (90 deg) to rotate pallet so 1200mm side faces camera -->
    <include>
      <uri>model://pallet</uri>
      <name>pallet_0deg</name>
      <pose>3.0 0 0 0 0 1.5708</pose>
    </include>

    <!-- Gazebo ROS state plugin for teleop control -->
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/gazebo</namespace>
      </ros>
      <update_rate>100.0</update_rate>
    </plugin>

    <!-- Camera (fixed position looking at pallet) -->
    <!-- RealSense camera height: 40cm from ground -->
    <model name="camera_model">
      <static>true</static>
      <pose>0 0 0.4 0 0 0</pose>
      <link name="camera_link">
        <visual name="camera_visual">
          <geometry>
            <box>
              <size>0.05 0.1 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.3 0.3 0.3 1</diffuse>
          </material>
        </visual>
        <sensor name="camera" type="camera">
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>1280</width>
              <height>720</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>
          </camera>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>true</visualize>
          <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
            <ros>
              <namespace>/</namespace>
              <remapping>image_raw:=camera/image_raw</remapping>
              <remapping>camera_info:=camera/camera_info</remapping>
            </ros>
            <camera_name>camera</camera_name>
            <frame_name>camera_link</frame_name>
          </plugin>
        </sensor>
      </link>
    </model>

  </world>
</sdf>
